TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
VLESS_URL=vless://uuid@example.com:443?type=tcp&security=tls&encryption=none&sni=example.com#message-fixer-bot
# Put real TELEGRAM_BOT_TOKEN and VLESS_URL in .env or Kubernetes secrets. Never commit production secrets.
TELEGRAM_UPDATE_TIMEOUT=60
XRAY_LOG_LEVEL=warning
